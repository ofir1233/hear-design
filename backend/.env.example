# ── PostgreSQL (Render managed DB — copy the "Internal Database URL") ──
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Groq (already have this) ──
GROQ_API_KEY=your_groq_key_here

# ── Resend (get free key at resend.com) ──
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── App ──
PORT=3001
FRONTEND_URL=https://your-frontend.onrender.com   # Render static site URL
APP_URL=https://your-backend.onrender.com         # This backend's URL (for magic links)
FROM_EMAIL=noreply@yourdomain.com                 # Must be a verified Resend domain
